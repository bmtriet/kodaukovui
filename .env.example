# AI provider
AI_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=your_gemini_token_here
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1

# Global popup hotkey
HOTKEY_POPUP=<ctrl>+'

# UI
UI_LANGUAGE=en
DEBUG=false
